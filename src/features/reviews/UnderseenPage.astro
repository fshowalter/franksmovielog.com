---
import { getEntries } from "astro:content";
import { getEntry } from "astro:content";

import ReviewsLayout from "./ReviewsLayout.astro";

const underseen = await getEntry("underseen", "underseen");

if (!underseen) {
  throw new Error("Failed to load underseen titles.");
}

const titles = await getEntries(underseen.data.titles);

const deck =
  "Four and five star movies with a below average number of IMDb votes.";
const metaDescription =
  "Looking for something new? Behold my four and five star reviews of movies with a below average number of IMDb votes.";
---

<ReviewsLayout
  activeTab="underseen"
  backdropSlug="underseen"
  deck={deck}
  metaDescription={metaDescription}
  pageTitle="Underseen Gems"
  title="Underseen"
  titles={titles}
/>
