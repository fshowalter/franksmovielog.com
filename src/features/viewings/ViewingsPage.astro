---
import { getCollection } from "astro:content";

import HeroLayout from "~/components/layout/HeroLayout.astro";
import { getViewingLogProps } from "~/features/viewings/getViewingsProps";
import { Viewings } from "~/features/viewings/Viewings";

const viewingLogEntries = await getCollection("viewingLog");

const viewingsProps = await getViewingLogProps(
  viewingLogEntries.map((e) => e.data),
);

const title = "Viewing Log";
const deck = '"We have such sights to show you!"';
const metaDescription =
  "A list of every movie I've seen since 2012. Filter by title, release year, viewing year, venue, medium, or genre. Sort by oldest or newest.";
---

<HeroLayout
  baseLayoutProps={{
    canonical: true,
    meta: {
      description: metaDescription,
    },
    openGraph: {
      description: deck,
      type: "website",
    },
    title,
  }}
  heroProps={{
    backdropSlug: "viewings",
    deck,
    title,
  }}
>
  <Viewings client:load {...viewingsProps} />
</HeroLayout>
