---
type Props = {
  callouts: {
    label: string;
    reviewed: number;
    sublabel?: string;
    total: number;
  }[];
};

const { callouts } = Astro.props;
---

<div
  class={`
    mx-auto w-full max-w-(--breakpoint-desktop)
    tablet:mt-12 tablet:px-container
  `}
>
  <div class={`flex w-full flex-wrap justify-center gap-8 px-container py-10`}>
    {
      callouts.map((callout) => {
        const { label, reviewed, sublabel, total } = callout;
        const percent = Math.floor((reviewed / total) * 100);
        return (
          <div
            class={`
              flex flex-col items-center
              first:min-w-full
              tablet:first:min-w-0
            `}
          >
            <svg
              class={`
                h-auto w-32
                tablet:w-36
              `}
              height={144}
              viewBox="0 0 36 36"
              width={144}
            >
              <path
                d="M18 2.0845
          a 15.9155 15.9155 0 0 1 0 31.831
          a 15.9155 15.9155 0 0 1 0 -31.831"
                fill={"var(--background-color-default" as const}
                stroke="var(--background-color-canvas)"
                stroke-width={1.8}
              />
              <path
                d="M18 2.0845
          a 15.9155 15.9155 0 0 1 0 31.831
          a 15.9155 15.9155 0 0 1 0 -31.831"
                fill={"none" as const}
                stroke="var(--background-color-progress)"
                stroke-dasharray={`${percent}, 100`}
                stroke-linecap="round"
                stroke-width={1.8}
              />
              <text
                fill="var(--color-default)"
                font-size=".5em"
                text-anchor="middle"
                x="18"
                y="17"
              >
                {percent}%
              </text>
              <text
                class="font-sans"
                fill="var(--color-default)"
                font-size=".2em"
                text-anchor="middle"
                x="18"
                y="23"
              >
                {label}
              </text>
              <text
                class="font-sans"
                fill="var(--color-subtle)"
                font-size=".2em"
                text-anchor="middle"
                x="18"
                y="27"
              >
                {sublabel}
              </text>
            </svg>
            <div
              class={`
                pt-2 text-center font-sans text-base font-semibold text-muted
              `}
            >
              {reviewed.toLocaleString()} / {total.toLocaleString()}
              <div
                class={`
                  font-sans text-sm/4 font-normal tracking-prose text-subtle
                `}
              >
                Reviewed
              </div>
            </div>
          </div>
        );
      })
    }
  </div>
</div>
