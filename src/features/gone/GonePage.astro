---
import HeroLayout from "~/components/layout/HeroLayout.astro";

const title = "410: Gone";
const deck = `"Forget it, Jake. It's Chinatown."`;
---

<HeroLayout
  baseLayoutProps={{
    canonical: false,
    meta: {
      description: deck,
    },
    openGraph: false,
    title,
  }}
  heroProps={{
    backdropSlug: "gone",
    centerText: true,
    deck,
    size: "large",
    title,
  }}
/>
