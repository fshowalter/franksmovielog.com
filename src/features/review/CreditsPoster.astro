---
import type { HTMLAttributes } from "astro/types";

import type { PosterImageProps } from "~/assets/posters";

type Props = HTMLAttributes<"img"> & {
  class?: string;
  decoding: "async" | "auto" | "sync";
  imageProps: PosterImageProps | undefined;
  loading: "eager" | "lazy";
};

const {
  class: className,
  decoding,
  imageProps,
  loading,
  ...rest
} = Astro.props;
---

<img
  {...rest}
  {...imageProps}
  alt=""
  class:list={["aspect-poster", className]}
  decoding={decoding}
  loading={loading}
/>
