---
import HeroLayout from "~/components/layout/HeroLayout.astro";

const title = "404: Not Found";
const deck = '"Dick Laurent is dead."';
---

<HeroLayout
  baseLayoutProps={{
    canonical: false,
    meta: {
      description: deck,
    },
    openGraph: false,
    title,
  }}
  heroProps={{
    backdropSlug: "not-found",
    centerText: true,
    deck,
    size: "large",
    title,
  }}
/>
