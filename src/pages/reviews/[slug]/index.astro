---
import type { CollectionEntry } from "astro:content";

import { getCollection } from "astro:content";

import ReviewPage from "~/features/review/ReviewPage.astro";

type Props = {
  reviewedTitle: CollectionEntry<"reviewedTitles">["data"];
};

export async function getStaticPaths() {
  const reviewedTitles = await getCollection("reviewedTitles");

  return reviewedTitles.map(({ data: reviewedTitle }) => {
    return {
      params: {
        slug: reviewedTitle.review.id,
      },
      props: {
        reviewedTitle,
      },
    };
  });
}

const { reviewedTitle } = Astro.props;
---

<ReviewPage reviewedTitle={reviewedTitle} />
