---
import type { CollectionEntry } from "astro:content";

import { getCollection } from "astro:content";

import CollectionTitlesPage from "~/features/collection-titles/CollectionTitlesPage.astro";

type Props = {
  collection: CollectionEntry<"collections">["data"];
};

export async function getStaticPaths() {
  const collections = await getCollection("collections");

  return collections.map(({ data: collection }) => {
    return {
      params: {
        slug: collection.slug,
      },
      props: { collection },
    };
  });
}

const { collection } = Astro.props;
---

<CollectionTitlesPage collection={collection} />
