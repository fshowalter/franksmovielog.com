---
import { getCollection } from "astro:content";

import YearStatsPage from "~/features/stats/YearStatsPage.astro";

export async function getStaticPaths() {
  const yearStatsEntries = await getCollection("yearStats");

  return yearStatsEntries.map(({ data: stats }) => {
    return {
      params: {
        year: stats.year,
      },
      props: {
        stats,
      },
    };
  });
}

const { stats } = Astro.props;
---

<YearStatsPage stats={stats} />
