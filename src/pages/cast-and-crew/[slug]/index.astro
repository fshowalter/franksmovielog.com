---
import type { CollectionEntry } from "astro:content";

import { getCollection } from "astro:content";

import CastAndCrewMemberPage from "~/features/cast-and-crew-member/CastAndCrewMemberPage.astro";

type Props = {
  castAndCrewMember: CollectionEntry<"castAndCrew">["data"];
};

export async function getStaticPaths() {
  const castAndCrew = await getCollection("castAndCrew");

  return castAndCrew.map(({ data: castAndCrewMember }) => {
    return {
      params: {
        slug: castAndCrewMember.slug,
      },
      props: { castAndCrewMember },
    };
  });
}

const { castAndCrewMember } = Astro.props;
---

<CastAndCrewMemberPage castAndCrewMember={castAndCrewMember} />
