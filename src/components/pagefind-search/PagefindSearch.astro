---
type Props = {
  class?: string;
  isGlobal?: boolean;
  variant?: "button" | "text";
};

const { class: className, isGlobal = false, variant = "button" } = Astro.props;

const dataProperties = isGlobal ? { "data-global": true } : {};
---

<pagefind-search class={className} {...dataProperties}>
  <div class="transition-colors">
    <button
      aria-keyshortcuts="Control+K"
      aria-label="Search"
      class:list={[
        `
          flex transform-gpu cursor-pointer items-center justify-center
          overflow-hidden text-sm/6 ring-default transition-all duration-500
          hover:text-accent
        `,
        variant === "button" && "laptop:ml-6",
      ]}
      data-open-search
      disabled
      title="Search: Control+K"
      type="button"
    >
      {variant === "text" && <span class="pr-3 text-2xl">Search</span>}
      <div
        class:list={[
          variant === "button" && `flex size-10 items-center justify-center`,
        ]}
      >
        <svg
          aria-hidden="true"
          class="size-7"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>
    </button>
  </div>
  <dialog
    aria-label="Search"
    class={`
      fixed inset-x-4 m-auto mt-16 w-full scale-0 rounded-lg border
      border-default bg-default whitespace-normal shadow-lg transition-all
      duration-500
      backdrop:bg-footer/60 backdrop:transition-normal
      open:block open:scale-100
      open:backdrop:backdrop-filter-[blur(1px)]
      tablet:mx-auto tablet:h-min tablet:max-w-[min(100vw-64px,36rem)]
      tablet:rounded-xl
      starting:open:scale-0
    `}
  >
    <div
      class={`
        flex max-h-[calc(100vh-160px)] safari-border-radius-fix flex-col
        tablet:max-h-[min(100vh-128px,900px)]
      `}
      data-dialog-frame
    >
      <button
        class={`
          absolute right-4 z-sticky mt-5 h-6 cursor-pointer rounded-sm
          border-none bg-subtle px-2 font-mono text-xs font-light text-muted
          transition-all
          hover:scale-105 hover:bg-accent hover:text-white
          focus:outline-accent
          tablet:right-6
          laptop:right-8
        `}
        data-close-search>ESC</button
      >
      {/* Fixed Search Input Section */}
      <div class="flex flex-none flex-col">
        {/* Search Form with magnifying glass icon */}
        <form aria-label="Site search" onsubmit="return false" role="search">
          <div class="relative">
            {/* Magnifying glass icon */}
            <svg
              aria-hidden="true"
              class={`
                pointer-events-none absolute top-4.5 left-4 size-5 text-default
                opacity-70
              `}
              fill="none"
              height="18"
              viewBox="0 0 18 18"
              width="18"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M12.7549 11.255H11.9649L11.6849 10.985C12.6649 9.845 13.2549 8.365 13.2549 6.755C13.2549 3.165 10.3449 0.255005 6.75488 0.255005C3.16488 0.255005 0.254883 3.165 0.254883 6.755C0.254883 10.345 3.16488 13.255 6.75488 13.255C8.36488 13.255 9.84488 12.665 10.9849 11.685L11.2549 11.965V12.755L16.2549 17.745L17.7449 16.255L12.7549 11.255ZM6.75488 11.255C4.26488 11.255 2.25488 9.245 2.25488 6.755C2.25488 4.26501 4.26488 2.255 6.75488 2.255C9.24488 2.255 11.2549 4.26501 11.2549 6.755C11.2549 9.245 9.24488 11.255 6.75488 11.255Z"
                fill="currentColor"></path>
            </svg>

            {/* Search input */}
            <input
              aria-describedby="search-box-counter"
              aria-label="Search query"
              autocapitalize="off"
              autocomplete="off"
              autocorrect="off"
              autofocus
              class={`
                h-14 w-full border-0 bg-transparent pr-17.5 pl-13.5 font-serif
                text-lg font-normal text-default outline-none
                placeholder:text-muted placeholder:opacity-50
                focus:outline-none
                [&::-ms-clear]:hidden [&::-ms-clear]:appearance-none
                [&::-webkit-search-cancel-button]:hidden
                [&::-webkit-search-cancel-button]:appearance-none
              `}
              enterkeyhint="search"
              id="search-box-input"
              placeholder="Search"
              spellcheck="false"
              type="search"
            />
          </div>
        </form>

        {/* Results message/counter */}
        <div
          aria-atomic="true"
          aria-live="polite"
          class={`
            border-y border-default p-4 font-sans text-xs font-normal
            text-subtle
            empty:hidden
          `}
          id="search-box-counter"
          role="status"
        >
        </div>
      </div>
      <div class={`flex flex-auto flex-col overflow-auto`}>
        {/* Scrollable Results Area */}
        <div
          aria-label="Search results"
          class={`
            flex-1 overflow-x-clip -outline-offset-2
            focus:outline-accent
          `}
          id="search-box-results-wrapper"
          role="region"
          tabindex="0"
        >
          <div class={`bg-subtle`} id="search-box-results"></div>

          {/* Load More Button */}
          <div
            class="hidden border-t border-default bg-subtle p-4"
            id="search-box-load-more-wrapper"
          >
            <div class="has-[button:hover]:drop-shadow-lg">
              <button
                aria-controls="search-box-results"
                class={`
                  mx-auto block h-10 w-full max-w-107.5 cursor-pointer
                  rounded-sm bg-default font-sans text-sm font-bold text-accent
                  uppercase transition-all
                  hover:scale-105 hover:bg-accent hover:text-white
                `}
                id="search-box-load-more"
                type="button"
              >
                Load more results
              </button>
            </div>
          </div>
        </div>
      </div>
      <div
        class={`
          flex flex-none items-center justify-start border-t border-t-default
          bg-default p-4 font-sans text-xs font-light tracking-wide text-subtle
          drop-shadow-2xl
          tablet:px-6
          laptop:block laptop:px-8
        `}
      >
        <kbd class={`rounded-md bg-default p-2 font-mono text-xs text-subtle`}
          >Tab</kbd
        > to navigate
        <kbd
          class={`ml-4 rounded-md bg-default p-2 font-mono text-xs text-subtle`}
          >ESC</kbd
        > to close
      </div>
    </div>
  </dialog>

  {
    /* <template> content is inert until cloned by search-box.ts.
         Tailwind 4.x scans .astro source files — classes inside <template> tags
         are found and included in the CSS output. */
  }

  {
    /* Single search result item; data-field attributes filled by cloneResult() */
  }
  <template data-result-item>
    <li
      class={`
        group/list-item relative mb-1 flex transform-gpu
        grid-cols-[min(25%,80px)_1fr] gap-x-6 bg-default px-[8%] py-6
        transition-all
        tablet:px-6
        tablet-landscape:has-[a:hover]:z-5
        tablet-landscape:has-[a:hover]:-translate-y-2
        tablet-landscape:has-[a:hover]:drop-shadow-2xl
        laptop:px-8
      `}
    >
      <div
        class={`
          relative w-1/4 max-w-[250px] shrink-0 self-start overflow-hidden
          rounded-sm shadow-all
          after:absolute after:top-0 after:left-0 after:z-sticky after:size-full
          after:bg-default after:opacity-15 after:transition-all
          after:duration-500
          group-has-[a:hover]/list-item:after:opacity-0
        `}
        data-field="image-wrapper"
      >
        <img
          alt=""
          class={`
            aspect-poster w-full transform-gpu object-cover transition-transform
            duration-500
            group-has-[a:hover]/list-item:scale-110
          `}
          data-field="image"
          loading="lazy"
          src=""
        />
      </div>
      <div class="min-w-0 flex-1">
        <h3 class={`mb-2 font-serif text-md/6 font-semibold text-default`}>
          <a
            class={`
              block text-default transition-colors
              after:absolute after:top-0 after:left-0 after:z-sticky
              after:size-full after:opacity-0
              hover:text-accent
            `}
            data-field="link"
            href=""></a>
        </h3>
        <p class="text-base text-default" data-field="excerpt"></p>
      </div>
    </li>
  </template>

  {/* Loading skeleton — 3 copies cloned while search is in-flight */}
  <template data-skeleton>
    <div class="animate-pulse p-4">
      <div
        class={`
          grid grid-cols-[min(25%,80px)_1fr] gap-x-6 px-[8%] py-6
          tablet:px-6
          laptop:px-8
        `}
      >
        <div class="h-12 w-full shrink-0 bg-subtle"></div>
        <div class="min-w-0 flex-1">
          <div class="mb-2 h-5 w-3/4 bg-subtle"></div>
          <div class="h-3 w-full bg-subtle"></div>
          <div class="mt-1 h-3 w-5/6 bg-subtle"></div>
        </div>
      </div>
    </div>
  </template>

  {/* Empty state — shown when search returns no results */}
  <template data-empty>
    <div class="px-4 py-8 text-center font-sans text-sm text-subtle">
      No results found. Try adjusting your search terms.
    </div>
  </template>

  {/* Error state — data-field="message" textContent filled by renderError() */}
  <template data-error>
    <div
      class="px-4 py-8 text-center font-sans text-sm text-subtle"
      data-field="message"
    >
    </div>
  </template>
</pagefind-search>
<script src="./pagefind-search.ts"></script>
