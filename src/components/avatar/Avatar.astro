---
import { getAvatarImageProps } from "~/assets/avatars";

type Props = {
  class?: string;
  imageConfig: {
    height: number;
    width: number;
  };
  loading: "eager" | "lazy";
  slug: string | undefined;
};

const { class: className, imageConfig, loading, slug } = Astro.props;

const imageProps = await getAvatarImageProps(slug, imageConfig);
---

{
  imageProps ? (
    <img alt="" {...imageProps} class={className} loading={loading} />
  ) : (
    <div>
      <div class={className}>
        <svg
          fill="var(--background-color-canvas)"
          viewBox="0 0 16 16"
          width="100%"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            clip-rule="evenodd"
            d="M16 8A8 8 0 110 8a8 8 0 0116 0zm-6-3a2 2 0 11-4 0 2 2 0 014 0zM8 9a5 5 0 00-4.546 2.916A5.986 5.986 0 008 14a5.986 5.986 0 004.546-2.084A5 5 0 008 9z"
            fill-rule="evenodd"
          />
        </svg>
      </div>
    </div>
  )
}
