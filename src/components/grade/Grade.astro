---
import { gradeMap } from "./gradeMap";

type Props = {
  class?: string;
  height: 15 | 16 | 18 | 24 | 32;
  value: string;
};

const { class: className, height, value } = Astro.props;

const [src, alt] = gradeMap[value];

const width = height * 5;
---

<picture>
  <source
    media="(prefers-color-scheme: dark)"
    src-set={src.replace(".svg", "-dark.svg")}
  />
  <img
    alt={`${value}: ${alt}`}
    class={className}
    height={height}
    src={src}
    width={width}
  />
</picture>
