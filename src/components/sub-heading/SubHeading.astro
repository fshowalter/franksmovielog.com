---
type Props = {
  children: unknown;
  class?: string;
  level: "h2" | "h3" | "h4" | "h5";
};

const { class: className, level: HeadingTag } = Astro.props;
---

<HeadingTag
  class:list={[
    `py-10 font-sans text-xs font-bold tracking-wide text-subtle uppercase`,
    className,
  ]}
>
  <slot />
</HeadingTag>
